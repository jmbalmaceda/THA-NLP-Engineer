MISTRAL_API_KEY=your_mistral_api_key_here
APPLICANT_EMAIL=your_email@example.com
MISTRAL_MODEL=mistral-small-latest

# Menu source: 'static' (default, hardcoded) or 'mongodb'
MENU_SOURCE=static

# Required only when MENU_SOURCE=mongodb
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=food_ordering
MONGODB_COLLECTION=menu

# ── Voice mode (--voice flag) ─────────────────────────────────────────────────
# STT provider: whisper (default, local) | google (cloud, no key needed)
STT_PROVIDER=whisper
# TTS provider: say (default, macOS built-in) | pyttsx3 (cross-platform) | edge (cloud, high quality)
TTS_PROVIDER=say

# Whisper: model size — tiny | base (default) | small | medium | large
# Larger = more accurate but slower to load
WHISPER_MODEL=base

# macOS say: leave blank to use system defaults
SAY_VOICE=
SAY_RATE=

# Microsoft Edge TTS: BCP-47 voice name (only used when TTS_PROVIDER=edge)
EDGE_TTS_VOICE=en-US-JennyNeural
